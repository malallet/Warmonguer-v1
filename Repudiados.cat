rue" includeChildForces="true" /></constraints><conditions><condition id="96b67f2d-0163-41d5-883d-802f6dea70ca" type="atLeast" field="selections" scope="parent" childId="Montura" value="1" shared="false" includeChildSelections="true" includeChildForces="true" /></conditions></selectionEntryGroup><selectionEntryGroup id="3b9d9adc-c909-4af4-8e00-6dcaab943c0d" name="Hierbas místicas" hidden="false" minSelections="0" maxSelections="3"><entryLinks><entryLink id="73f16bf4-32a2-47d5-8f63-2cec6eb48268" name="Hierbas místicas" type="selectionEntry" targetId="16299c1c-f388-443c-a608-2702fcc39dab" /></entryLinks></selectionEntryGroup></selectionEntryGroups></selectionEntry></selectionEntries><sharedRules><rule id="0e640b48-89d4-496e-83f4-94d7ffc861b8" name="Repudiados"><description>Los Veteranos de los Repudiados funcionan como Guerreros a la hora de interactuar con Objetivos en los escenarios. El Líder de la banda de Repudiados no contará con ninguna de sus reglas especiales (aunque sí dará el marcador de Pavor a toda su banda si es Abatido).</description></rule></sharedRules><sharedSelectionEntries><selectionEntry id="4e330c2a-3a04-4c6c-a311-6cff98bf059d" name="Bruja" type="upgrade" hidden="false"><costs><cost name="pts" typeId="points" value="15" /></costs><profiles><profile id="ae40a144-e27c-4195-a8b3-0a450a2fc473" name="Bruja" typeId="82af-8e9c-23fd-789f" typeName="Mejora"><characteristics><characteristic name="Efecto">Uno solo por banda.</characteristic></characteristics></profile></profiles><constraints><constraint id="f3e5acd7-13f6-4273-8f75-ad522a8a6373" type="max" field="selections" scope="roster" value="1" shared="false" includeChildSelections="true" includeChildForces="true" /></constraints></selectionEntry></sharedSelectionEntries><forceEntries><forceEntry id="03a884bd-5dc3-4400-adc8-d9bfecfac525" name="Banda Repudiados" hidden="false"><categoryLinks /><entryLinks><entryLink id="03647a2a-7b7f-4118-bf3d-0539db1176ee" name="Guerrero (Repudiados)" type="selectionEntry" targetId="25b4b2d4-755d-4a30-b6a9-cf2c8f52eee0" /><entryLink id="8c2b0a02-a3a0-4c75-a694-742bab1c7c0a" name="Veterano (Repudiados)" type="selectionEntry" targetId="a68f9a49-86bc-43b2-89cb-ee568a3deeaf" /><entryLink id="ce93b09e-0c5a-44b9-bef1-d87fa5658d36" name="Héroe (Repudiados)" type="selectionEntry" targetId="540287ac-9c71-4be4-987e-180bbcf92944" /><entryLink id="8dbf9983-c59d-41bc-a235-9581eb02916b" name="Hechicero (Repudiados)" type="selectionEntry" targetId="5d96e8d3-f5bc-4b18-a87d-32f45179c078" /><entryLink id="7ff00f65-eabb-471b-80bc-09a58b7ec038" name="Criatura (Repudiados)" type="selectionEntry" targetId="f17dd45b-bc62-4a3c-93c0-8e06f08d73ae" /></entryLinks></forceEntry></forceEntries></catalogue>